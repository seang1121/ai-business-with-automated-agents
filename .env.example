# =============================================================
# AI Business with Automated Agents — Environment Variables
# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================

# Claude API (required for live mode)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Twilio SMS (required for live mode SMS notifications)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Dashboard PIN (6-digit code to access the owner dashboard)
DASHBOARD_PIN=123456

# OpenClaw Integration (optional)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-token

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-string
